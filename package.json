{
  "name": "cmake-depcheck",
  "version": "1.3.0",
  "description": "Check for updates to CMake FetchContent dependencies",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "cmake-depcheck": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmnq-f/cmake-depcheck.git"
  },
  "homepage": "https://github.com/dmnq-f/cmake-depcheck#readme",
  "bugs": {
    "url": "https://github.com/dmnq-f/cmake-depcheck/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:action": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "prepare": "npm run build"
  },
  "keywords": [
    "cmake",
    "fetchcontent",
    "dependency",
    "updater"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^10.1.0",
    "prettier": "^3.5.3",
    "rollup": "^4.60.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
