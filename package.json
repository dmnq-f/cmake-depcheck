{
  "name": "cmake-depcheck",
  "version": "0.1.0",
  "description": "Check for updates to CMake FetchContent dependencies",
  "main": "dist/index.js",
  "bin": {
    "cmake-depcheck": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "prepare": "npm run build"
  },
  "keywords": [
    "cmake",
    "fetchcontent",
    "dependency",
    "updater"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
